{
  "name": "sentinella-monorepo",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:backend": "pnpm --filter @sentinella/backend run start:dev",
    "dev:frontend": "pnpm --filter @sentinella/frontend run dev",
    "build:backend": "pnpm --filter @sentinella/backend run build",
    "build:frontend": "pnpm --filter @sentinella/frontend run build",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
