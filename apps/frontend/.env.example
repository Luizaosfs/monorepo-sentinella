# ─── NestJS Backend ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3333

# ─── Supabase (legado — remover após Fase 2 da migração) ─────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Cloudinary (upload de imagens / evidências) ─────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ─── Sentry — deixar vazio em dev para desativar (só envia erros em produção) ─
VITE_SENTRY_DSN=

# ─── Google Maps (geocodificação em NotificadorRegistroCaso) ─────────────────
# ATENÇÃO: Esta chave é exposta no bundle do browser (é pública por natureza).
# A proteção real é feita no Google Cloud Console:
#   1. Ativar APENAS as APIs necessárias: Geocoding API
#   2. Restringir por HTTP Referrer:
#      - Produção:    https://app.sentinella.com.br/*
#      - Homologação: https://homolog.sentinella.com.br/*
#      - Dev local:   http://localhost:5173/*
# Ver: docs/GOOGLE_MAPS_KEY_SETUP_SEGURO.md
VITE_GOOGLE_MAPS_API_KEY=

# ─── APP_ORIGIN (CORS das Edge Functions) ────────────────────────────────────
# Domínio do frontend — usado como Access-Control-Allow-Origin nas Edge Functions.
# Configurar via `npx supabase secrets set APP_ORIGIN=https://app.sentinella.com.br`
# APP_ORIGIN=https://app.sentinella.com.br   # configurar nos secrets do Supabase, não aqui

# ─── Edge Functions — secrets configurados via `supabase secrets set` ────────
# Não entram no .env local; documentados aqui como checklist de deploy.
#
# RESEND_API_KEY=           # relatório semanal (relatorio-semanal)
# ANTHROPIC_API_KEY=        # triagem IA pós-voo + identify-larva
# VAPID_PUBLIC_KEY=         # Web Push (sla-push-critico, notif-canal-cidadao)
# VAPID_PRIVATE_KEY=        # Web Push
# VAPID_SUBJECT=            # Web Push — ex: mailto:suporte@sentinella.app
# CRON_SECRET=              # autenticação de jobs agendados (billing, health, pluvio, score, limpeza…)
# CLOUDINARY_API_KEY=       # cloudinary-cleanup-orfaos
# CLOUDINARY_API_SECRET=    # cloudinary-cleanup-orfaos
#
# Configurar com:
#   npx supabase secrets set RESEND_API_KEY=xxx ANTHROPIC_API_KEY=xxx APP_ORIGIN=https://app.sentinella.com.br ...
