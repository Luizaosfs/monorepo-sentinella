# ============================================================================
# .env.test.example — copie para .env.test (ignorado pelo git) e ajuste a senha
# do PostgreSQL local. Lista exaustiva das variáveis exigidas por
# src/lib/env/server.ts (Zod). Variáveis com .default() ainda precisam estar
# explícitas aqui para evitar drift se o default mudar no schema.
# ============================================================================

# === DATABASE ===
# DB dedicado ao e2e — criar antes:  createdb -U postgres sentinella_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinella_test?schema=public

# === AUTH (obrigatórias) ===
SECRET_JWT=test_jwt_secret_minimum_32_characters_xxx
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# === SERVER ===
PORT=3333
NODE_ENV=test
CLIENT_URL=http://localhost:3000

# === Canal Cidadão v2 ===
CANAL_CIDADAO_IP_SALT=test_salt
CANAL_CIDADAO_V2_ENABLED=true

# === SMTP (opcional — sem default exigido, mas explícito p/ não vazar host real) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# === Cloudinary (opcional) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Anthropic (opcional) ===
ANTHROPIC_API_KEY=

# === e-SUS / SINAN (opcional) ===
ESUS_API_URL=
ESUS_API_TOKEN=

# === CNES (opcional) ===
CNES_API_URL=

# === Web Push (opcional) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
