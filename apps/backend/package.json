{
  "name": "@sentinella/backend",
  "version": "0.1.0",
  "description": "Backend API Sentinella Web — NestJS + Prisma + Zod (padrão ManFrota SOLID)",
  "author": "Luiz Antônio",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run generate && nest build",
    "prisma:push": "prisma db push --schema ./prisma/schema",
    "prisma:pull": "prisma db pull --schema ./prisma/schema",
    "generate": "prisma generate --schema ./prisma/schema",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start -- --prod",
    "start:dev": "nest start --watch --no-debug -- --dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main -- --prod",
    "lint": "biome check ./src",
    "test": "jest --config jest.config.ts --testPathIgnorePatterns='.e2e.spec.ts$'",
    "test:e2e": "jest --config jest.e2e.config.ts --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "7.7.0",
    "@scalar/nestjs-api-reference": "^0.4.3",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "glob": "^11.0.3",
    "helmet": "^8.1.0",
    "nestjs-cls": "^6.0.1",
    "nestjs-zod": "^4.3.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-mock-extended": "4.0.0-beta1",
    "prettier": "^3.4.2",
    "prisma": "7.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
