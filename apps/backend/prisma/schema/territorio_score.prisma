model territorio_score {
  cliente_id    String    @db.Uuid
  imovel_id     String    @db.Uuid
  score         Decimal   @default(0) @db.Decimal(5, 2)
  classificacao String    @default("baixo")
  fatores       Json      @default("{}")
  calculado_em  DateTime  @default(now()) @db.Timestamptz
  versao_config DateTime? @db.Timestamptz
  updated_at    DateTime  @default(now()) @db.Timestamptz

  @@id([cliente_id, imovel_id])
  @@map("territorio_score")
}
