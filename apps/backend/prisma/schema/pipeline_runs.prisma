model pipeline_runs {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id           String    @db.Uuid
  voo_id               String?   @db.Uuid
  levantamento_id      String?   @db.Uuid
  status               String    @default("em_andamento")
  total_imagens        Int?
  imagens_processadas  Int?
  itens_gerados        Int?
  focos_criados        Int?
  erro_mensagem        String?
  erro_detalhe         Json?
  versao_pipeline      String?
  iniciado_em          DateTime  @default(now()) @db.Timestamptz
  concluido_em         DateTime? @db.Timestamptz
  duracao_s            Int?
  created_at           DateTime  @default(now()) @db.Timestamptz

  @@map("pipeline_runs")
  @@schema("public")
}
