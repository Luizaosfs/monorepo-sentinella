model canal_cidadao_rate_log {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id String   @db.Uuid
  ip_hash    String
  motivo     String
  foco_id    String?  @db.Uuid
  detalhes   Json?
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([cliente_id])
  @@index([ip_hash, created_at])
  @@index([motivo])
  @@map("canal_cidadao_rate_log")
  @@schema("public")
}
