model planos {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome                     String
  descricao                String?
  preco_mensal             Decimal?  @db.Decimal(10, 2)
  limite_usuarios          Int?
  limite_imoveis           Int?
  limite_vistorias_mes     Int?
  limite_levantamentos_mes Int?
  limite_voos_mes          Int?
  limite_storage_gb        Decimal?  @db.Decimal(10, 2)
  limite_ia_calls_mes      Int?
  limite_denuncias_mes     Int?
  drone_habilitado         Boolean   @default(false)
  sla_avancado             Boolean   @default(false)
  integracoes_habilitadas  String[]  @default([])
  ativo                    Boolean   @default(true)
  ordem                    Int       @default(0)
  created_at               DateTime  @default(now()) @db.Timestamptz

  cliente_plano cliente_plano[]

  @@map("planos")
  @@schema("public")
}
