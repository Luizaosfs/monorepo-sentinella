model sentinela_risk_defaults {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policy_id          String   @db.Uuid
  chuva_relevante_mm Decimal  @db.Decimal(10, 2)
  dias_lookup_max    Int
  tendencia_dias     Int
  created_at         DateTime @default(now()) @db.Timestamptz

  policy sentinela_risk_policy @relation(fields: [policy_id], references: [id])
  @@map("sentinela_risk_defaults")
  @@schema("public")
}
