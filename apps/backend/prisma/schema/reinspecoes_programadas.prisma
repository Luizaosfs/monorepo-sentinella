model reinspecoes_programadas {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id          String    @db.Uuid
  foco_risco_id       String    @db.Uuid
  status              String    @default("pendente")
  tipo                String    @default("eficacia_pos_tratamento")
  origem              String    @default("automatico")
  data_prevista       DateTime  @db.Timestamptz
  data_realizada      DateTime? @db.Timestamptz
  responsavel_id      String?   @db.Uuid
  observacao          String?
  resultado           String?
  criado_por          String?   @db.Uuid
  cancelado_por       String?   @db.Uuid
  motivo_cancelamento String?
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @default(now()) @db.Timestamptz

  @@map("reinspecoes_programadas")
}
