model foco_risco_historico {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  foco_risco_id          String   @db.Uuid
  cliente_id             String   @db.Uuid
  status_anterior        String?
  status_novo            String
  alterado_por           String?  @db.Uuid
  alterado_em            DateTime @default(now()) @db.Timestamptz
  tipo_evento            String?
  classificacao_anterior String?
  classificacao_nova     String?
  motivo                 String?

  foco    focos_risco @relation(fields: [foco_risco_id], references: [id])
  cliente clientes    @relation(fields: [cliente_id], references: [id])

  @@index([cliente_id])
  @@index([cliente_id, alterado_em])
  @@index([foco_risco_id])
  @@map("foco_risco_historico")
  @@schema("public")
}
