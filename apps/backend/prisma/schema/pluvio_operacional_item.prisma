model pluvio_operacional_item {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_id                 String   @db.Uuid
  regiao_id              String?  @db.Uuid
  bairro_nome            String
  classificacao_risco    String
  situacao_ambiental     String?
  chuva_24h_mm           Decimal? @db.Decimal(10, 2)
  chuva_72h_mm           Decimal? @db.Decimal(10, 2)
  chuva_7d_mm            Decimal? @db.Decimal(10, 2)
  dias_com_chuva_7d      Int?
  janela_sem_chuva       String?
  persistencia_7d        String?
  tendencia              String?
  temp_media_c           Decimal? @db.Decimal(6, 2)
  vento_medio_kmh        Decimal? @db.Decimal(6, 2)
  prob_label             String?
  prob_base_min          Decimal? @db.Decimal(6, 2)
  prob_base_max          Decimal? @db.Decimal(6, 2)
  prob_final_min         Decimal? @db.Decimal(6, 2)
  prob_final_max         Decimal? @db.Decimal(6, 2)
  criadouro_ativo        String?
  velocidade_ciclo       String?
  janela_emergencia_dias String?
  prioridade_operacional String
  prazo_acao             String?
  created_at             DateTime @default(now()) @db.Timestamptz

  run pluvio_operacional_run @relation(fields: [run_id], references: [id])
  @@map("pluvio_operacional_item")
}
