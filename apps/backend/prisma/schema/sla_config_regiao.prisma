model sla_config_regiao {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id String   @db.Uuid
  bairro_id  String   @db.Uuid
  config     Json     @default("{}")
  created_at DateTime @db.Timestamptz
  updated_at DateTime @db.Timestamptz

  cliente clientes @relation(fields: [cliente_id], references: [id])
  bairro  bairros  @relation(fields: [bairro_id], references: [id])

  @@index([cliente_id])
  @@index([bairro_id])
  @@map("sla_config_regiao")
  @@schema("public")
}
