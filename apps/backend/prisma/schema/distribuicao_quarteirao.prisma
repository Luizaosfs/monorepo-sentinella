model bairros_distribuicao {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id String   @db.Uuid
  ciclo_id   String?  @db.Uuid
  quadra_id  String   @db.Uuid
  agente_id  String   @db.Uuid
  bairro_id  String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  ciclo_rel  ciclos?         @relation(fields: [ciclo_id],  references: [id], onDelete: Restrict)
  quadra_rel bairros_quadras @relation(fields: [quadra_id], references: [id], onDelete: Restrict)

  @@unique([cliente_id, ciclo_id, quadra_id])
  @@index([agente_id])
  @@index([bairro_id])
  @@index([ciclo_id])
  @@index([quadra_id])
  @@map("bairros_distribuicao")
  @@schema("public")
}

model bairros_distribuicao_historico {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id String   @db.Uuid
  ciclo_id   String   @db.Uuid
  quadra_id  String   @db.Uuid
  agente_id  String?  @db.Uuid
  acao       String
  usuario_id String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([ciclo_id])
  @@index([quadra_id])
  @@index([cliente_id])
  @@map("bairros_distribuicao_historico")
  @@schema("public")
}
