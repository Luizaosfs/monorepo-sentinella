model distribuicao_quarteirao {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id String   @db.Uuid
  ciclo      Int
  quarteirao String
  agente_id  String   @db.Uuid
  regiao_id  String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  quarteirao_rel quarteiroes? @relation(fields: [cliente_id, quarteirao], references: [cliente_id, codigo])
  @@unique([cliente_id, ciclo, quarteirao])
  @@index([agente_id])
  @@index([regiao_id])
  @@map("distribuicao_quarteirao")
  @@schema("public")
}
