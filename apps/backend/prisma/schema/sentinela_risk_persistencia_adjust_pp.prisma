model sentinela_risk_persistencia_adjust_pp {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policy_id String @db.Uuid
  idx       Int
  dias_min  Int
  dias_max  Int
  delta_pp  Int

  policy sentinela_risk_policy @relation(fields: [policy_id], references: [id])
  @@map("sentinela_risk_persistencia_adjust_pp")
}
