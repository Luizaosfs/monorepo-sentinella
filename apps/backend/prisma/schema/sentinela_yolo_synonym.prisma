model sentinela_yolo_synonym {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id String   @db.Uuid
  synonym    String
  maps_to    String
  created_at DateTime @default(now()) @db.Timestamptz

  @@unique([cliente_id, synonym])
  @@index([cliente_id])
  @@map("sentinela_yolo_synonym")
  @@schema("public")
}
