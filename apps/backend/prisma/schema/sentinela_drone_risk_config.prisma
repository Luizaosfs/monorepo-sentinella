model sentinela_drone_risk_config {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id            String   @db.Uuid
  base_by_risco         Json     @default("{\"alto\": 85, \"baixo\": 25, \"medio\": 55}")
  priority_thresholds   Json     @default("{\"P1\": 85, \"P2\": 60, \"P3\": 40, \"P4\": 20, \"P5\": 0}")
  sla_by_priority_hours Json     @default("{\"P1\": 24, \"P2\": 72, \"P3\": 168, \"P4\": 336, \"P5\": 720}")
  confidence_multiplier Decimal  @default(1.0)
  item_overrides        Json     @default("{}")
  created_at            DateTime @default(now()) @db.Timestamptz
  updated_at            DateTime @default(now()) @db.Timestamptz

  @@index([cliente_id])
  @@map("sentinela_drone_risk_config")
  @@schema("public")
}
