model levantamento_item_evidencias {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  item_id     String   @db.Uuid
  tipo        String?
  url         String
  public_id   String?
  created_at  DateTime @default(now()) @db.Timestamptz

  item levantamento_itens @relation(fields: [item_id], references: [id])

  @@index([item_id])
  @@map("levantamento_item_evidencias")
  @@schema("public")
}
