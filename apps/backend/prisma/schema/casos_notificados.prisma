model casos_notificados {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id           String    @db.Uuid
  unidade_saude_id     String    @db.Uuid
  notificador_id       String?   @db.Uuid
  doenca               String    @default("suspeito")
  status               String    @default("suspeito")
  data_inicio_sintomas DateTime? @db.Date
  data_notificacao     DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  logradouro_bairro    String?
  bairro               String?
  latitude             Float?
  longitude            Float?
  bairro_id            String?   @db.Uuid
  observacao           String?
  payload              Json?
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @default(now()) @db.Timestamptz
  deleted_at           DateTime? @db.Timestamptz
  deleted_by           String?   @db.Uuid
  created_by           String?   @db.Uuid

  // E.1.1 — Vínculo operacional principal caso ↔ foco
  // Permanece histórico mesmo após descarte do caso (auditoria/rastreabilidade).
  // Valores de foco_vinculo_tipo: 'existente_300m' | 'criado_por_caso' | 'pendente_geocodificacao'
  foco_risco_id                 String?  @db.Uuid
  foco_vinculado_em             DateTime? @db.Timestamptz
  foco_vinculo_tipo             String?
  foco_vinculo_distancia_metros Float?

  cliente       clientes       @relation(fields: [cliente_id], references: [id])
  unidade_saude unidades_saude @relation(fields: [unidade_saude_id], references: [id])
  notificador   usuarios?      @relation("caso_notificador", fields: [notificador_id], references: [id])
  @@index([cliente_id])
  @@index([cliente_id, status])
  @@index([cliente_id, created_at])
  @@index([bairro_id])
  @@index([foco_risco_id])
  @@map("casos_notificados")
  @@schema("public")
}
