model levantamento_item_status_historico {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levantamento_item_id   String   @db.Uuid
  cliente_id             String   @db.Uuid
  status_anterior        String?
  status_novo            String
  acao_aplicada_anterior String?
  acao_aplicada_nova     String?
  alterado_por           String?  @db.Uuid
  alterado_em            DateTime @default(now()) @db.Timestamptz

  @@index([cliente_id])
  @@index([cliente_id, alterado_em])
  @@index([levantamento_item_id])
  @@index([levantamento_item_id, alterado_em])
  @@map("levantamento_item_status_historico")
  @@schema("public")
}
