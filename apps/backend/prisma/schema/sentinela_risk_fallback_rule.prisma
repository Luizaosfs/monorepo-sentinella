model sentinela_risk_fallback_rule {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policy_id             String   @db.Uuid
  situacao_ambiental    String
  probabilidade_label   String
  probabilidade_pct_min Int
  probabilidade_pct_max Int
  classificacao         String
  icone                 String
  severity              Int
  created_at            DateTime @default(now()) @db.Timestamptz

  policy sentinela_risk_policy @relation(fields: [policy_id], references: [id])
  @@map("sentinela_risk_fallback_rule")
  @@schema("public")
}
