model import_log {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id     String    @db.Uuid
  criado_por     String?   @db.Uuid
  filename       String
  total_linhas   Int       @default(0)
  importados     Int       @default(0)
  com_erro       Int       @default(0)
  ignorados      Int       @default(0)
  duplicados     Int       @default(0)
  geocodificados Int       @default(0)
  geo_falhou     Int       @default(0)
  status         String    @default("em_andamento")
  erros          Json?
  created_at     DateTime  @default(now()) @db.Timestamptz
  finished_at    DateTime? @db.Timestamptz

  @@map("import_log")
  @@schema("public")
}
