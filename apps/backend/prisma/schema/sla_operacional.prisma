model sla_operacional {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  item_id                String?   @db.Uuid
  operador_id            String?   @db.Uuid
  prioridade             String
  sla_horas              Int
  inicio                 DateTime  @default(now()) @db.Timestamptz
  prazo_final            DateTime  @db.Timestamptz
  concluido_em           DateTime? @db.Timestamptz
  status                 String    @default("pendente")
  violado                Boolean   @default(false)
  escalonado             Boolean   @default(false)
  escalonado_em          DateTime? @db.Timestamptz
  prioridade_original    String?
  cliente_id             String?   @db.Uuid
  levantamento_item_id   String?   @db.Uuid
  escalonado_automatico  Boolean   @default(false)
  foco_risco_id          String?   @db.Uuid
  escalado_por           String?   @db.Uuid
  reaberto_por           String?   @db.Uuid
  deleted_at             DateTime? @db.Timestamptz
  deleted_by             String?   @db.Uuid
  created_at             DateTime  @default(now()) @db.Timestamptz
  updated_at             DateTime  @default(now()) @db.Timestamptz

  operador   usuarios?    @relation("sla_operador", fields: [operador_id], references: [id])
  foco_risco focos_risco? @relation(fields: [foco_risco_id], references: [id])
  cliente    clientes?    @relation(fields: [cliente_id], references: [id])

  @@index([cliente_id])
  @@index([cliente_id, status])
  @@index([foco_risco_id])
  @@index([status])
  @@map("sla_operacional")
  @@schema("public")
}
