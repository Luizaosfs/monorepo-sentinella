model cliente_plano {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id           String    @unique @db.Uuid
  plano_id             String    @db.Uuid
  data_inicio          DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  data_fim             DateTime? @db.Date
  status               String    @default("ativo")
  limites_personalizados Json?
  contrato_ref         String?
  observacao           String?
  data_trial_fim       DateTime? @db.Timestamptz
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @default(now()) @db.Timestamptz

  cliente clientes @relation(fields: [cliente_id], references: [id])
  plano   planos   @relation(fields: [plano_id], references: [id])

  billing_ciclo billing_ciclo[]

  @@index([cliente_id])
  @@map("cliente_plano")
  @@schema("public")
}
