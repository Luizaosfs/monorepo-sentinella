model levantamentos {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id           String    @db.Uuid
  planejamento_id      String?   @db.Uuid
  ciclo_id             String?   @db.Uuid
  id_drone             String?   @db.Uuid
  usuario_id           String    @db.Uuid
  titulo               String?
  tipo_entrada         String?
  config_fonte         String?
  data_voo             DateTime? @db.Date
  status_processamento String?   @default("aguardando")
  total_itens          Int       @default(0)
  observacao           String?
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @default(now()) @db.Timestamptz
  concluido_em         DateTime? @db.Timestamptz
  deleted_at           DateTime? @db.Timestamptz
  deleted_by           String?   @db.Uuid

  cliente  clientes  @relation(fields: [cliente_id], references: [id])
  usuario  usuarios  @relation(fields: [usuario_id], references: [id])
  ciclo    ciclos?   @relation(fields: [ciclo_id], references: [id])
  itens    levantamento_itens[]

  @@map("levantamentos")
  @@schema("public")
}
