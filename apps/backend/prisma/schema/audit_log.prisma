model audit_log {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tabela      String
  operacao    String
  registro_id String?
  usuario_id  String?  @db.Uuid
  cliente_id  String?  @db.Uuid
  dados_antes Json?
  dados_depois Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  @@map("audit_log")
  @@schema("public")
}
