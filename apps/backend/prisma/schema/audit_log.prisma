model audit_log {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id   String?  @db.Uuid
  usuario_id   String?  @db.Uuid
  tabela       String?
  registro_id  String?  @db.Uuid
  dados_antes  Json?
  dados_depois Json?
  operacao     String?
  created_at   DateTime @default(now()) @db.Timestamptz

  @@index([cliente_id])
  @@index([cliente_id, created_at])
  @@index([tabela, registro_id, created_at])
  @@map("audit_log")
  @@schema("public")
}
