model sla_erros_criacao {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levantamento_item_id String?   @db.Uuid
  erro                 String
  criado_em            DateTime  @default(now()) @db.Timestamptz
  retention_until      DateTime  @default(dbgenerated("(now() + '90 days'::interval)")) @db.Timestamptz
  cliente_id           String?   @db.Uuid
  item_id              String?   @db.Uuid
  contexto             Json?
  created_at           DateTime  @default(now()) @db.Timestamptz

  @@map("sla_erros_criacao")
  @@schema("public")
}
