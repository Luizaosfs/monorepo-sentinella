model yolo_feedback {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levantamento_item_id  String   @db.Uuid
  cliente_id            String   @db.Uuid
  confirmado            Boolean
  observacao            String?
  registrado_por        String?  @db.Uuid
  created_at            DateTime @default(now()) @db.Timestamptz

  @@index([cliente_id])
  @@index([levantamento_item_id])
  @@map("yolo_feedback")
  @@schema("public")
}
