# === DATABASE ===
DATABASE_URL=postgresql://postgres:senha@localhost:5432/sentinella?schema=public

# === AUTH ===
SECRET_JWT=sua-chave-secreta-jwt-256bits
JWT_EXPIRES_IN=7d
# Tempo de vida do refresh token. Aceita unidades: s, m, h, d.
# Default: 30d. Recomendado: 7d-30d dependendo do modelo de sessão.
REFRESH_TOKEN_EXPIRES_IN=30d

# === SERVER ===
PORT=3333
NODE_ENV=development
# CSV de origens CORS permitidas. Obrigatório fora de NODE_ENV=development.
# Exemplo: CLIENT_URL=https://app.sentinella.com.br,https://admin.sentinella.com.br
CLIENT_URL=

# === CLOUDINARY (upload de evidências) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === CLAUDE HAIKU VISION (identify-larva) ===
ANTHROPIC_API_KEY=

# === e-SUS / SINAN ===
ESUS_API_URL=
ESUS_API_TOKEN=

# === CNES SYNC ===
CNES_API_URL=https://apidadosabertos.saude.gov.br

# === PUSH NOTIFICATIONS (Web Push) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@sentinellaweb.com.br

# === SMTP (envio de email próprio — recuperação de senha) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sentinellaweb.com.br
