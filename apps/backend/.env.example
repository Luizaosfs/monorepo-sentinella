# === DATABASE ===
DATABASE_URL=postgresql://postgres:senha@localhost:5432/sentinella?schema=public

# === AUTH ===
SECRET_JWT=sua-chave-secreta-jwt-256bits
JWT_EXPIRES_IN=7d

# === SERVER ===
PORT=3333
NODE_ENV=development

# === CLOUDINARY (upload de evidências) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === CLAUDE HAIKU VISION (identify-larva) ===
ANTHROPIC_API_KEY=

# === e-SUS / SINAN ===
ESUS_API_URL=
ESUS_API_TOKEN=

# === CNES SYNC ===
CNES_API_URL=https://apidadosabertos.saude.gov.br

# === PUSH NOTIFICATIONS (Web Push) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@sentinellaweb.com.br

# === SMTP (envio de email próprio — recuperação de senha) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sentinellaweb.com.br

# === SUPABASE BRIDGE (manter enquanto tokens antigos circulam no AuthGuard) ===
# SUPABASE_JWT_SECRET aceita tokens Supabase legados — remover quando todos usuários relogarem
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
