{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "prisma.config.ts",
    "jest.config.ts",
    "jest.e2e.config.ts",
    "**/*.spec.ts",
    "**/*.e2e.spec.ts",
    "**/*.test.ts",
    "**/__tests__/**",
    "src/**/use-cases/test/**"
  ]
}
